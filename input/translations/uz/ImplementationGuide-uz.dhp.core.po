msgstr "Sog‘liqni saqlash vazirligi ma’muriy hududi"

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid ""
"State Committee on Statistics (SSV) administrative territory codes for "
"Uzbekistan"
msgstr ""
"O‘zbekiston bo‘yicha Davlat statistika qo‘mitasi (SSV) ma’muriy hudud "
"kodlari\n"

# ImplementationGuide.definition.resource.name
#: ImplementationGuide.definition.resource.name
msgid "SSV Administrative Territory to Regions and States"
msgstr ""
"Sog‘liqni saqlash vazirligi ma’muriy hududlarini tumanlar va viloyatlarga "
"moslashtirish\n"

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid ""
"Maps SSV administrative territory codes to UZ Core StateCS (for regions) and "
"RegionsCS (for districts). Both systems use NATE codes as their underlying "
"identifiers, making this a direct equivalence mapping. Locality-level codes "
"(9213 entries) from the SSV system have no equivalent in the target and are "
"excluded from this map."
msgstr ""
"Sog‘liqni saqlash vazirligi ma’muriy hudud kodlarini UZ Core StateCS "
"(viloyatlar uchun) va RegionsCS (tumanlar uchun) kodlariga moslashtiradi. "
"Har ikkala tizim ham asosiy identifikator sifatida NATE kodlaridan "
"foydalanadi, shu sababli bu bevosita ekvivalentlik moslashtirishidir. "
"Sog‘liqni saqlash vazirligi tizimidagi aholi punkti darajasidagi kodlarning "
"(9213 ta yozuv) maqsadli tizimda ekvivalenti yo‘q va ular ushbu xaritadan "
"chiqarib tashlangan.\n"

# ImplementationGuide.definition.resource.name
#: ImplementationGuide.definition.resource.name
msgid "SSV Level Type to Subordination Group"
msgstr ""
"Sog‘liqni saqlash vazirligi daraja turini Subordination Group ga "
"moslashtirish\n"

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid ""
"Maps SSV organization level type codes to UZ Core Organizational "
"Subordination Group codes. SSV classifies healthcare facilities into "
"administrative levels, while OrganizationalSubordinationGroupCS groups "
"institutions by their administrative subordination (republican, territorial, "
"district/city, other ministries, private). The SSV level types Shahar (Urban)"
", Tuman (Area), and Mahalla (District) all fall under the combined district-"
"and-city administration category in the target."
msgstr ""
"Sog‘liqni saqlash vazirligi tashkilot darajasi turi kodlarini UZ Core "
"Organizational Subordination Group kodlariga moslashtiradi. Sog‘liqni "
"saqlash vazirligi tibbiyot muassasalarini ma’muriy darajalar bo‘yicha "
"tasniflaydi, OrganizationalSubordinationGroupCS esa muassasalarni ularning "
"ma’muriy bo‘ysunuvi bo‘yicha guruhlaydi (respublika, hududiy, tuman/shahar, "
"boshqa vazirliklar, xususiy). Sog‘liqni saqlash vazirligi tizimidagi Shahar, "
"Tuman va Mahalla daraja turlari maqsadli tizimdagi birlashtirilgan tuman-"
"shahar boshqaruvi toifasiga kiradi."

# ImplementationGuide.definition.resource.name
#: ImplementationGuide.definition.resource.name
msgid "SSV Medical Type to Organizational Structure"
msgstr ""
"Sog‘liqni saqlash vazirligi tibbiy turini Organizational Structure ga "
"moslashtirish\n"

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid ""
"Maps SSV medical type codes to UZ Core Organizational Structure codes. SSV "
"classifies healthcare facilities into 45 medical types, while "
"OrganizationalStructureCS provides the Ministry of Health's detailed "
"classification of institution types."
msgstr ""
"Sog‘liqni saqlash vazirligi tibbiy tur kodlarini UZ Core Organizational "
"Structure kodlariga moslashtiradi. Sog‘liqni saqlash vazirligi tibbiyot "
"muassasalarini 45 ta tibbiy turga tasniflaydi, OrganizationalStructureCS esa "
"Sog‘liqni saqlash vazirligi tomonidan belgilangan muassasa turlarining "
"batafsil tasnifini taqdim etadi."

# ImplementationGuide.definition.resource.name
#: ImplementationGuide.definition.resource.name
msgid "SSV Service Type to Organizational Service Group"
msgstr ""
"Sog‘liqni saqlash vazirligi xizmat turini Organizational Service Group ga "
"moslashtirish"

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid ""
"Maps SSV service type codes to UZ Core Organizational Service Group codes. "
"SSV uses service type classification per organization, while "
"OrganizationalServiceGroupCS uses a single pre-combined classification. When "
"an organization has multiple SSV service types, the combination should be "
"considered to select the appropriate target code (e.g. Inpatient + "
"Outpatient together maps to III_100)."
msgstr ""
"Sog‘liqni saqlash vazirligi xizmat turi kodlarini UZ Core Organizational "
"Service Group kodlariga moslashtiradi. Sog‘liqni saqlash vazirligi har bir "
"tashkilot bo‘yicha xizmat turi tasnifidan foydalanadi, "
"OrganizationalServiceGroupCS esa yagona oldindan birlashtirilgan tasnifdan "
"foydalanadi. Agar tashkilotda bir nechta Sog‘liqni saqlash vazirligi xizmat "
"turi mavjud bo‘lsa, tegishli maqsadli kodni tanlash uchun ularning "
"kombinatsiyasi hisobga olinishi kerak (masalan, Statsionar + ambulatoriya "
"birgalikda III_100 ga moslashtiriladi)."

