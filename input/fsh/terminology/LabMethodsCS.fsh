CodeSystem: LabMethodsCS
Id: lab-methods-cs
Title: "Laboratory technique (method of measurement)"
Description: "Laboratory technique (method of measurement) used for the result measurement"
* insert OriginalCodeSystemDraft(lab-methods-cs)

* #lab-method-1 "PZR (Polimeraza zanjir reaksiyasi)"
  * ^designation[0].language = #ru
  * ^designation[=].value = "ПЦР"
  * ^designation[+].language = #en
  * ^designation[=].value = "PCR (Polymerase Chain Reaction)"

* #lab-method-2 "IFA (Immunoferment tahlil)"
  * ^designation[0].language = #ru
  * ^designation[=].value = "ИФА"
  * ^designation[+].language = #en
  * ^designation[=].value = "EIA (Enzyme Immunoassay)"

* #lab-method-3 "ELISA"
  * ^designation[0].language = #ru
  * ^designation[=].value = "ELISA"
  * ^designation[+].language = #en
  * ^designation[=].value = "ELISA (Enzyme-Linked Immunosorbent Assay)"

* #lab-method-4 "Kultural usul"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Культуральный метод"
  * ^designation[+].language = #en
  * ^designation[=].value = "Culture method"

